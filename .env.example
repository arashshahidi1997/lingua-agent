# Provider selection: mock | openai | anthropic | claude-max
#
# - mock         deterministic stubs (default, no network, used by tests)
# - openai       any OpenAI-compatible endpoint (OpenAI, Ollama, Gemma via
#                Google AI Studio, Qwen via DashScope, OpenRouter, vLLM, ...)
# - anthropic    Claude API with prompt caching (needs ANTHROPIC_API_KEY)
# - claude-max   Claude Pro/Max subscription via Claude Code CLI's OAuth.
#                NO API KEY NEEDED. Calls bill against your subscription quota
#                instead of API token usage. Requires `claude login` once.
LINGUA_AI_PROVIDER=mock

# ─── Backend presets — pick ONE block and copy it above ────────────────────
#
# OpenAI
#   LINGUA_AI_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_MODEL=gpt-4o-mini
#
# Google AI Studio (Gemma family) — get a key at https://aistudio.google.com/
#   LINGUA_AI_PROVIDER=openai
#   OPENAI_API_KEY=AIza...
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   OPENAI_MODEL=gemma-3-27b-it
#
# Ollama running locally (Gemma)  ── no API key needed for localhost
#   LINGUA_AI_PROVIDER=openai
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_MODEL=gemma3:12b
#
# Ollama running locally (Qwen)
#   LINGUA_AI_PROVIDER=openai
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_MODEL=qwen3:14b
#
# DashScope (Alibaba — Qwen cloud, OpenAI-compatible mode)
#   LINGUA_AI_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   OPENAI_MODEL=qwen3-max
#
# OpenRouter (any model — cloud proxy)
#   LINGUA_AI_PROVIDER=openai
#   OPENAI_API_KEY=sk-or-...
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_MODEL=google/gemma-3-27b-it
#
# vLLM / llama.cpp server / LM Studio (local)
#   LINGUA_AI_PROVIDER=openai
#   OPENAI_BASE_URL=http://localhost:8000/v1
#   OPENAI_MODEL=<your model name>
#
# ───────────────────────────────────────────────────────────────────────────

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic API (set when LINGUA_AI_PROVIDER=anthropic).
# Skip the API key when using LINGUA_AI_PROVIDER=claude-max — that path uses
# your Claude Code CLI's OAuth session and your Pro/Max subscription quota.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama base URL (used by the mock-friendly defaults; you can also set
# OPENAI_BASE_URL=http://localhost:11434/v1 directly)
OLLAMA_BASE_URL=http://localhost:11434

# Data directory (defaults to ./.lingua-agent under the working directory)
LINGUA_DATA_DIR=
