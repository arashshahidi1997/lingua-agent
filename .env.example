# Provider selection: mock | openai | anthropic
LINGUA_AI_PROVIDER=mock

# OpenAI-compatible (also works with local LLMs that expose this API, e.g. llama.cpp, vLLM, LM Studio)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (alternative local endpoint)
OLLAMA_BASE_URL=http://localhost:11434

# Data directory (defaults to ./.lingua-agent under the working directory)
LINGUA_DATA_DIR=
